{
  "functions": {
    "api/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://chill-sip.firebaseapp.com/__/auth/:path*"
    },
    {
      "source": "/__/firebase/:path*",
      "destination": "https://chill-sip.firebaseapp.com/__/firebase/:path*"
    }
  ]
}